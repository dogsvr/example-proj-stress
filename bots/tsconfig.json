{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "bundler",
        "ignoreDeprecations": "6.0",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "outDir": "dist",
        "rootDir": "src",
        "declaration": false,
        "sourceMap": true,
        "resolveJsonModule": true
    },
    "include": ["src/**/*"]
}
