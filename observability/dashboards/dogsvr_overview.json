{
  "title": "dogsvr Overview",
  "uid": "dogsvr-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "P99 cmd duration (ms) by cmdId",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(dogsvr_cmd_duration_milliseconds_bucket[1m])) by (le, cmdId, svr))",
        "legendFormat": "{{svr}}/{{cmdId}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "QPS by cmdId",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(dogsvr_cmd_duration_milliseconds_count[1m])) by (cmdId, svr)",
        "legendFormat": "{{svr}}/{{cmdId}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "txn pending (gauge)",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "dogsvr_txn_pending", "legendFormat": "{{svr}}", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "txn timeout rate",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "rate(dogsvr_txn_timeout_total[1m])", "legendFormat": "{{svr}}", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Node.js eventloop lag (s)",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "{{svr}}/{{role}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "P99 mongo op (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(mongo_op_duration_milliseconds_bucket[1m])) by (le, coll, op))",
        "legendFormat": "{{coll}}.{{op}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "P99 redis op (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(redis_op_duration_milliseconds_bucket[1m])) by (le, op))",
        "legendFormat": "{{op}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Process CPU (s)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "rate(process_cpu_time_seconds_total[1m])",
        "legendFormat": "{{svr}}/{{role}}",
        "refId": "A"
      }]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Process RSS (bytes)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{
        "expr": "process_resident_memory_bytes",
        "legendFormat": "{{svr}}/{{role}}",
        "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    }
  ]
}
